{
  "manifest_version": 3,
  "name": "DogLight",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "downloads",
    "tabs"
  ],
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "DogLight",
    "default_popup": "src/viewer/viewer.html"
  },
  "content_scripts": [
    {
      "matches": ["https://dogflight.io/*"], 
      "js": ["src/content/content.ts"]
    }
  ]
}