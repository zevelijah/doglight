{
  "manifest_version": 3,
  "name": "DogLight",
  "version": "1.0.1",
  "version_name": "1.0.1 (beta)",
  "description": "Provides session-by-session game statistics for dogflight.io.",
  "icons": {
    "16": "assets/doglight-icon-16.png",
    "32": "assets/doglight-icon-32.png",
    "48": "assets/doglight-icon-48.png",
    "128": "assets/doglight-icon-128.png"
  },  
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "DogLight",
    "default_popup": "src/viewer/viewer.html?mode=popup"
  },
  "content_scripts": [
    {
      "matches": ["https://dogflight.io/*"], 
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://dogflight.io/*"],
      "js": ["src/injected/injected.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}